"""
Swaps every two adjacent nodes in a singly-linked list.
"""

from preloaded import Node
def swap_pairs(head):
    """
    Swaps every two adjacent nodes in a singly-linked list.
    """
    if not head or not head.next:
        return head

    res_head = head.next
    prev = None
    curr = head

    while curr and curr.next:
        first = curr
        second = curr.next
        next_pair = second.next

        second.next = first
        first.next = next_pair

        if prev:
            prev.next = second

        prev = first
        curr = next_pair

    return res_head
