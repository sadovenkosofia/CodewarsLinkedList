"""
Module for working with singly linked lists.

This module provides the core Node class for building a linked list
and a function to remove duplicate values from a sorted linked list.
"""
class Node(object):
    def __init__(self, data):
        self.data = data
        self.next = None

def remove_duplicates(head):
    """
    Removes duplicate nodes from a sorted singly linked list in place.
    """
    if head is None:
        return head
    prev = head
    curr = head.next

    while curr is not None and prev.data == curr.data:
        curr = curr.next

    prev.next = curr
    while curr is not None:
        if curr.next is not None and curr.data == curr.next.data:
            curr = curr.next
            continue

        prev.next = curr

        prev = curr
        curr = curr.next
    return head
